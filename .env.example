# ========================================
# AI 模型配置（二选一，DeepSeek 优先）
# ========================================

# 【推荐】DeepSeek：如果填写此项，将优先使用 DeepSeek
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# 【备用】OpenAI：只在未填写 DEEPSEEK_API_KEY 时生效
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# ========================================
# 安全须知
# ========================================
# - API Key 只能放在服务端环境变量，不要加 NEXT_PUBLIC_ 前缀
# - 不要把真实 Key 提交到 GitHub
# - Vercel 部署时在「Settings > Environment Variables」配置相同变量
